<UserControl x:Class="Mood_Ring.Controls.MoodRingControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" MinWidth="60" MinHeight="60">
    <Grid>
        <!-- 배경 트랙 링 -->
        <Ellipse x:Name="Track" StrokeThickness="9" Stroke="#2A3340" Opacity="0.6" />

        <!-- 눈금(틱) — 코드에서 Geometry 생성 -->
        <Path x:Name="Ticks" Stroke="#46556B" StrokeThickness="1.5" Opacity="0.55" />

        <!-- 중앙 백드롭 (텍스트 가독성용 반투명 디스크) -->
        <Ellipse x:Name="InnerBackdrop" Margin="17" Fill="#C20E1116" Stroke="#1FFFFFFF" StrokeThickness="1">
            <Ellipse.Effect>
                <DropShadowEffect BlurRadius="12" ShadowDepth="0" Color="#000000" Opacity="0.55" />
            </Ellipse.Effect>
        </Ellipse>

        <!-- 글로우 (호흡 펄스 + 점수 기반 강도) -->
        <Ellipse x:Name="Glow" StrokeThickness="10" Opacity="0.4" RenderTransformOrigin="0.5,0.5">
            <Ellipse.RenderTransform>
                <ScaleTransform x:Name="GlowScale" ScaleX="1" ScaleY="1" />
            </Ellipse.RenderTransform>
            <Ellipse.Effect>
                <BlurEffect x:Name="GlowBlur" Radius="16" />
            </Ellipse.Effect>
        </Ellipse>

        <!-- 과열 시 회전 샤이머(점선 링) -->
        <Ellipse x:Name="Shimmer" Margin="2" StrokeThickness="2" Stroke="#99FFFFFF"
                 StrokeDashArray="1 7" StrokeDashCap="Round" Opacity="0" RenderTransformOrigin="0.5,0.5">
            <Ellipse.RenderTransform>
                <RotateTransform x:Name="ShimmerRot" Angle="0" />
            </Ellipse.RenderTransform>
        </Ellipse>

        <!-- 진행 아크 (12시 시작, 시계방향) -->
        <Path x:Name="ProgressPath" StrokeThickness="9" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
        <!-- 위에 얹는 하이라이트 시언 -->
        <Path x:Name="SheenPath" StrokeThickness="2.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
              Stroke="#73FFFFFF" Opacity="0.55" />

        <!-- 아크 끝 코멧(빛나는 점) -->
        <Ellipse x:Name="Comet" Width="13" Height="13" HorizontalAlignment="Left" VerticalAlignment="Top"
                 Visibility="Collapsed">
            <Ellipse.Effect>
                <BlurEffect Radius="6" />
            </Ellipse.Effect>
        </Ellipse>

        <!-- 중앙 텍스트 + 라벨 -->
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock x:Name="ValueText" Text="{Binding DisplayText}" Foreground="White"
                       HorizontalAlignment="Center" FontWeight="SemiBold" FontSize="19"
                       FontFamily="Segoe UI Emoji, Segoe UI Symbol, Segoe UI">
                <TextBlock.Effect>
                    <DropShadowEffect BlurRadius="6" ShadowDepth="0" Color="#000000" Opacity="0.7" />
                </TextBlock.Effect>
            </TextBlock>
            <TextBlock x:Name="LabelText" Text="{Binding MoodLabel}" Foreground="#B8C6D8"
                       HorizontalAlignment="Center" FontSize="9.5" FontWeight="Medium"
                       Margin="0,1,0,0" Opacity="0.85" />
        </StackPanel>
    </Grid>
</UserControl>
