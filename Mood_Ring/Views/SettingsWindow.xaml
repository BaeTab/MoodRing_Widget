<Window x:Class="Mood_Ring.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Mood Ring 설정" WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ResizeMode="NoResize" SizeToContent="Height" Width="340" Topmost="True"
        WindowStartupLocation="CenterScreen" FontFamily="Segoe UI">
    <Window.Resources>
        <Style x:Key="Section" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#6E8098" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Margin" Value="0,14,0,6" />
        </Style>
        <Style x:Key="Row" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#C9D6E6" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="Val" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#7FE3CF" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#C9D6E6" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="0,5,0,0" />
        </Style>
        <Style TargetType="Slider">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="IsSnapToTickEnabled" Value="False" />
        </Style>
    </Window.Resources>

    <Border Background="#F21A2230" CornerRadius="16" BorderBrush="#33FFFFFF" BorderThickness="1" Padding="0">
        <Border.Effect>
            <DropShadowEffect BlurRadius="28" ShadowDepth="0" Color="#000000" Opacity="0.6" />
        </Border.Effect>
        <StackPanel>
            <!-- 헤더 (드래그) -->
            <Grid x:Name="Header" Background="#01FFFFFF" MouseLeftButtonDown="Header_MouseLeftButtonDown" Margin="18,14,14,0">
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="11" Height="11" VerticalAlignment="Center"
                             Fill="#5EEAD4" />
                    <TextBlock Text="Mood Ring 설정" Foreground="White" FontSize="14" FontWeight="SemiBold"
                               Margin="8,0,0,0" VerticalAlignment="Center" />
                </StackPanel>
                <Button Content="✕" Click="Close_Click" HorizontalAlignment="Right" Width="26" Height="26"
                        Foreground="#9DB0C6" Background="Transparent" BorderThickness="0" FontSize="13"
                        Cursor="Hand" />
            </Grid>

            <StackPanel Margin="18,4,18,16">
                <!-- 외형 -->
                <TextBlock Text="외형" Style="{StaticResource Section}" />
                <Grid Margin="0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="170" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="색상 테마" Style="{StaticResource Row}" />
                    <ComboBox x:Name="ThemeCombo" Grid.Column="1" Height="26"
                              SelectedItem="{Binding ColorTheme, Mode=TwoWay}" SelectionChanged="OnComboChanged" />
                </Grid>
                <Grid Margin="0,6,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="170" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="표시 모드" Style="{StaticResource Row}" />
                    <ComboBox x:Name="ModeCombo" Grid.Column="1" Height="26"
                              SelectedItem="{Binding DisplayMode, Mode=TwoWay}" SelectionChanged="OnComboChanged" />
                </Grid>

                <CheckBox Content="색 전환 애니메이션" IsChecked="{Binding AnimateColor, Mode=TwoWay}" Click="OnToggle" />
                <CheckBox Content="점수 기반 글로우/펄스" IsChecked="{Binding ReactiveGlow, Mode=TwoWay}" Click="OnToggle" />
                <CheckBox Content="호버 시 상세 패널" IsChecked="{Binding ShowDetailOnHover, Mode=TwoWay}" Click="OnToggle" />

                <Grid Margin="0,9,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="40" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="평상시 투명도" Style="{StaticResource Row}" />
                    <Slider x:Name="IdleSlider" Grid.Column="1" Minimum="0.3" Maximum="1.0" Margin="8,0"
                            Value="{Binding IdleOpacity, Mode=TwoWay}" ValueChanged="OnSliderChanged" />
                    <TextBlock Grid.Column="2" Style="{StaticResource Val}"
                               Text="{Binding Value, ElementName=IdleSlider, StringFormat={}{0:0.00}}" />
                </Grid>

                <!-- 동작 -->
                <TextBlock Text="동작" Style="{StaticResource Section}" />
                <CheckBox Content="배터리 상태 보정" IsChecked="{Binding BatteryAdjustment, Mode=TwoWay}" Click="OnToggle" />
                <CheckBox Content="클릭 통과 (위젯 위 클릭 무시)" IsChecked="{Binding ClickThrough, Mode=TwoWay}" Click="OnToggle" />
                <CheckBox Content="윈도우 시작 시 자동 실행" IsChecked="{Binding AutoStart, Mode=TwoWay}" Click="OnToggle" />

                <Grid Margin="0,9,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="40" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="갱신 주기(ms)" Style="{StaticResource Row}" />
                    <Slider x:Name="IntervalSlider" Grid.Column="1" Minimum="250" Maximum="3000" Margin="8,0"
                            Value="{Binding UpdateIntervalMs, Mode=TwoWay}" ValueChanged="OnSliderChanged" />
                    <TextBlock Grid.Column="2" Style="{StaticResource Val}"
                               Text="{Binding Value, ElementName=IntervalSlider, StringFormat={}{0:0}}" />
                </Grid>
                <Grid Margin="0,6,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="40" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="스무딩(α)" Style="{StaticResource Row}" />
                    <Slider x:Name="AlphaSlider" Grid.Column="1" Minimum="0.05" Maximum="0.6" Margin="8,0"
                            Value="{Binding Alpha, Mode=TwoWay}" ValueChanged="OnSliderChanged" />
                    <TextBlock Grid.Column="2" Style="{StaticResource Val}"
                               Text="{Binding Value, ElementName=AlphaSlider, StringFormat={}{0:0.00}}" />
                </Grid>

                <!-- 가중치 -->
                <TextBlock Text="가중치" Style="{StaticResource Section}" />
                <Grid Margin="0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="50" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="40" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="CPU" Style="{StaticResource Row}" />
                    <Slider x:Name="CpuSlider" Grid.Column="1" Minimum="0" Maximum="1" Margin="8,0"
                            Value="{Binding CpuWeight, Mode=TwoWay}" ValueChanged="OnSliderChanged" />
                    <TextBlock Grid.Column="2" Style="{StaticResource Val}"
                               Text="{Binding Value, ElementName=CpuSlider, StringFormat={}{0:0.00}}" />
                </Grid>
                <Grid Margin="0,4,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="50" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="40" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="MEM" Style="{StaticResource Row}" />
                    <Slider x:Name="MemSlider" Grid.Column="1" Minimum="0" Maximum="1" Margin="8,0"
                            Value="{Binding MemoryWeight, Mode=TwoWay}" ValueChanged="OnSliderChanged" />
                    <TextBlock Grid.Column="2" Style="{StaticResource Val}"
                               Text="{Binding Value, ElementName=MemSlider, StringFormat={}{0:0.00}}" />
                </Grid>
                <Grid Margin="0,4,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="50" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="40" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="DISK" Style="{StaticResource Row}" />
                    <Slider x:Name="DiskSlider" Grid.Column="1" Minimum="0" Maximum="1" Margin="8,0"
                            Value="{Binding DiskWeight, Mode=TwoWay}" ValueChanged="OnSliderChanged" />
                    <TextBlock Grid.Column="2" Style="{StaticResource Val}"
                               Text="{Binding Value, ElementName=DiskSlider, StringFormat={}{0:0.00}}" />
                </Grid>
                <Grid Margin="0,4,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="50" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="40" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="NET" Style="{StaticResource Row}" />
                    <Slider x:Name="NetSlider" Grid.Column="1" Minimum="0" Maximum="1" Margin="8,0"
                            Value="{Binding NetworkWeight, Mode=TwoWay}" ValueChanged="OnSliderChanged" />
                    <TextBlock Grid.Column="2" Style="{StaticResource Val}"
                               Text="{Binding Value, ElementName=NetSlider, StringFormat={}{0:0.00}}" />
                </Grid>

                <!-- 푸터 -->
                <Grid Margin="0,18,0,0">
                    <Button Content="기본값 복원" Click="Reset_Click" HorizontalAlignment="Left"
                            Padding="12,6" Foreground="#9DB0C6" Background="#22324A" BorderThickness="0"
                            Cursor="Hand" FontSize="11" />
                    <Button Content="닫기" Click="Close_Click" HorizontalAlignment="Right"
                            Padding="18,6" Foreground="#0B1118" Background="#5EEAD4" BorderThickness="0"
                            Cursor="Hand" FontSize="11" FontWeight="SemiBold" />
                </Grid>
                <TextBlock Text="후원 토스뱅크 1001-2269-0600" Foreground="#42526A" FontSize="9"
                           HorizontalAlignment="Center" Margin="0,12,0,0" />
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
