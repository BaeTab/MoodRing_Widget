<Window x:Class="Mood_Ring.Views.RingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:Mood_Ring.Controls"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent" ShowInTaskbar="False"
        Topmost="True" ResizeMode="NoResize" SnapsToDevicePixels="True"
        Width="140" Height="140">
    <Window.Resources>
        <!-- 상세 패널 미니 막대 -->
        <Style x:Key="MiniBar" TargetType="ProgressBar">
            <Setter Property="Height" Value="6" />
            <Setter Property="Minimum" Value="0" />
            <Setter Property="Maximum" Value="100" />
            <Setter Property="Background" Value="#243040" />
            <Setter Property="Foreground" Value="#5EEAD4" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Border Background="{TemplateBinding Background}" CornerRadius="3">
                            <Border x:Name="PART_Track">
                                <Border x:Name="PART_Indicator" HorizontalAlignment="Left"
                                        Background="{TemplateBinding Foreground}" CornerRadius="3" />
                            </Border>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="MetricLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#8FA2B8" />
            <Setter Property="FontSize" Value="9.5" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="MetricValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#DCE6F2" />
            <Setter Property="FontSize" Value="9.5" />
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </Window.Resources>

    <Grid>
        <Border x:Name="RingHost" CornerRadius="500" Background="Transparent"
                MouseLeftButtonDown="Window_MouseLeftButtonDown" PreviewMouseWheel="Window_PreviewMouseWheel">
            <controls:MoodRingControl x:Name="Ring"
                Progress="{Binding CompositeScore}"
                RingColor="{Binding RingColor}"
                GlowIntensity="{Binding GlowIntensity}"
                MoodBand="{Binding MoodBand}" />
        </Border>

        <!-- 호버 상세 패널 -->
        <Popup x:Name="DetailPopup" PlacementTarget="{Binding ElementName=RingHost}" Placement="Bottom"
               AllowsTransparency="True" PopupAnimation="Fade" StaysOpen="True" VerticalOffset="6">
            <Border Background="#F2121821" CornerRadius="12" Padding="13,11" BorderBrush="#2EFFFFFF" BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="22" ShadowDepth="0" Color="#000000" Opacity="0.55" />
                </Border.Effect>
                <StackPanel Width="172">
                    <!-- 헤더 -->
                    <Grid>
                        <TextBlock Text="MOOD" Foreground="#6E7F95" FontSize="10" FontWeight="Bold"
                                   VerticalAlignment="Center" />
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <TextBlock Text="{Binding CompositeScore, StringFormat={}{0:0}}"
                                       Foreground="White" FontSize="16" FontWeight="Bold" />
                            <TextBlock Text="{Binding MoodLabel}" Foreground="#9DB0C6" FontSize="10"
                                       FontWeight="SemiBold" Margin="6,0,0,1" VerticalAlignment="Bottom" />
                        </StackPanel>
                    </Grid>

                    <Border Height="1" Background="#1EFFFFFF" Margin="0,8" />

                    <!-- 메트릭 막대 -->
                    <Grid Margin="0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="34" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="30" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="CPU" Style="{StaticResource MetricLabel}" />
                        <ProgressBar Grid.Column="1" Style="{StaticResource MiniBar}" Value="{Binding Cpu}" Foreground="#5EEAD4" Margin="4,0" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="2" Text="{Binding Cpu, StringFormat={}{0:0}}" Style="{StaticResource MetricValue}" />
                    </Grid>
                    <Grid Margin="0,3,0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="34" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="30" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="MEM" Style="{StaticResource MetricLabel}" />
                        <ProgressBar Grid.Column="1" Style="{StaticResource MiniBar}" Value="{Binding Memory}" Foreground="#A78BFA" Margin="4,0" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="2" Text="{Binding Memory, StringFormat={}{0:0}}" Style="{StaticResource MetricValue}" />
                    </Grid>
                    <Grid Margin="0,3,0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="34" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="30" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="DISK" Style="{StaticResource MetricLabel}" />
                        <ProgressBar Grid.Column="1" Style="{StaticResource MiniBar}" Value="{Binding Disk}" Foreground="#FBBF24" Margin="4,0" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="2" Text="{Binding Disk, StringFormat={}{0:0}}" Style="{StaticResource MetricValue}" />
                    </Grid>
                    <Grid Margin="0,3,0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="34" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="30" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="NET" Style="{StaticResource MetricLabel}" />
                        <ProgressBar Grid.Column="1" Style="{StaticResource MiniBar}" Value="{Binding Network}" Foreground="#38BDF8" Margin="4,0" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="2" Text="{Binding Network, StringFormat={}{0:0}}" Style="{StaticResource MetricValue}" />
                    </Grid>

                    <!-- 스파크라인 -->
                    <Border Margin="0,9,0,0" Height="34" Background="#16202C" CornerRadius="7" Padding="2">
                        <Polyline Points="{Binding SparklinePoints}" Stroke="{Binding RingBrush}"
                                  StrokeThickness="1.8" StrokeLineJoin="Round" Stretch="None" />
                    </Border>
                    <TextBlock Text="드래그 이동 · 휠 크기 · 더블클릭 모드" Foreground="#5A6A7E"
                               FontSize="8.5" HorizontalAlignment="Center" Margin="0,7,0,0" />
                </StackPanel>
            </Border>
        </Popup>
    </Grid>
</Window>
